{
  "schemaVersion": 1,
  "catalog": {
    "id": "artifact-chain-assistant",
    "version": "0.2.0"
  },
  "entries": [
    {
      "ref": "artifact.prd-feature.author",
      "provider": {
        "scope": "plugin",
        "plugin": "artifact-chain-assistant",
        "skill": "prd-feature-flow-author"
      },
      "kind": "workflow",
      "summary": "Author or revise PRD feature requirements with internal closure",
      "match": {
        "domains": ["artifact"],
        "artifactTypes": ["feature"],
        "intents": ["author", "create", "revise"]
      },
      "accepts": ["objective", "existing-artifact", "project-rules"],
      "produces": ["prd-feature", "final-result"],
      "sideEffects": ["write-project-artifacts"]
    },
    {
      "ref": "artifact.prd-feature.validate-links",
      "provider": {
        "scope": "plugin",
        "plugin": "artifact-chain-assistant",
        "skill": "prd-feature-link-validator"
      },
      "kind": "operation",
      "summary": "Validate PRD feature links with scenario scripts",
      "match": {
        "domains": ["artifact"],
        "artifactTypes": ["feature"],
        "intents": ["validate", "link-check"]
      },
      "accepts": ["artifact-paths"],
      "produces": ["validation-result"],
      "sideEffects": ["read-only"]
    }
  ]
}
