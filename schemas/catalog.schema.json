{
  "title": "Plugin Catalog",
  "description": "JSON Schema for a plugin catalog in the agent-method-registry protocol",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalog", "entries"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Must be exactly 1 for the current protocol version"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable plugin identifier"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Semantic version of the catalog"
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      }
    }
  },
  "$defs": {
    "pluginProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "plugin", "skill"],
      "properties": {
        "scope": {
          "const": "plugin"
        },
        "plugin": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domains", "artifactTypes", "intents"],
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "artifactTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "intents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "sideEffects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read-only", "write-project-artifacts", "external-state-change"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "pluginEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "provider", "kind", "summary", "match", "accepts", "produces", "sideEffects"],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Logical entry ID, stable across versions"
        },
        "provider": {
          "$ref": "#/$defs/pluginProvider"
        },
        "kind": {
          "type": "string",
          "enum": ["workflow", "operation"]
        },
        "summary": {
          "type": "string",
          "maxLength": 160,
          "description": "Human-readable summary, max 160 Unicode code points"
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "accepts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "produces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "sideEffects": {
          "$ref": "#/$defs/sideEffects"
        }
      }
    }
  }
}
