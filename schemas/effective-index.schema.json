{
  "title": "Effective Index",
  "description": "JSON Schema for an effective index in the agent-method-registry protocol",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "inputs", "entries", "disabledEntries"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/effectiveEntry"
      }
    },
    "disabledEntries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/disabledEntry"
      }
    }
  },
  "$defs": {
    "contentHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "pluginProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "plugin", "skill"],
      "properties": {
        "scope": { "const": "plugin" },
        "plugin": { "type": "string", "minLength": 1 },
        "skill": { "type": "string", "minLength": 1 }
      }
    },
    "projectProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "skill"],
      "properties": {
        "scope": { "const": "project" },
        "skill": { "type": "string", "minLength": 1 }
      }
    },
    "provider": {
      "oneOf": [
        { "$ref": "#/$defs/pluginProvider" },
        { "$ref": "#/$defs/projectProvider" }
      ]
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domains", "artifactTypes", "intents"],
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "artifactTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "intents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "sideEffects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read-only", "write-project-artifacts", "external-state-change"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "catalogInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "contentHash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "contentHash": { "$ref": "#/$defs/contentHash" }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalogs", "projectContentHash"],
      "properties": {
        "catalogs": {
          "type": "array",
          "items": { "$ref": "#/$defs/catalogInput" }
        },
        "projectContentHash": { "$ref": "#/$defs/contentHash" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceCatalog"],
      "properties": {
        "sourceCatalog": { "type": "string", "minLength": 1 },
        "overriddenBy": { "type": "string", "minLength": 1 }
      }
    },
    "effectiveEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "provider", "kind", "summary", "match", "accepts", "produces", "sideEffects", "provenance"],
      "properties": {
        "ref": { "type": "string", "minLength": 1, "maxLength": 128 },
        "provider": { "$ref": "#/$defs/provider" },
        "kind": { "type": "string", "enum": ["workflow", "operation"] },
        "summary": { "type": "string", "maxLength": 160 },
        "match": { "$ref": "#/$defs/match" },
        "accepts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "produces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "sideEffects": { "$ref": "#/$defs/sideEffects" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "disabledEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "provider", "sourceCatalog", "disabledBy"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "provider": { "$ref": "#/$defs/provider" },
        "sourceCatalog": { "type": "string", "minLength": 1 },
        "disabledBy": { "type": "string", "minLength": 1 }
      }
    }
  }
}
