{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://artifact-chain.dev/schemas/method-query.schema.json",
  "title": "Method Query",
  "description": "Structured standard-service query emitted after project-facts orientation and consumed by registry/planners",
  "type": "object",
  "required": [
    "schemaVersion",
    "mode",
    "candidateServices",
    "intent",
    "kind",
    "targetArtifact",
    "contractRevisionDigest",
    "projectFactsEvidenceDigest",
    "authorization",
    "registrySnapshot",
    "queryDigest"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "mode": {
      "type": "string",
      "const": "standard",
      "description": "Legacy/generic routes use a different protocol and cannot be mixed into a standard query"
    },
    "candidateServices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["serviceId", "apiId", "apiMajor", "apiRevisionDigest"],
        "additionalProperties": false,
        "properties": {
          "serviceId": {
            "type": "string",
            "pattern": "^artifact\\.[a-z][a-z0-9-]+\\.[a-z][a-z0-9-]+$"
          },
          "apiId": {
            "type": "string",
            "pattern": "^artifact\\.[a-z][a-z0-9-]*-family$"
          },
          "apiMajor": { "type": "integer", "minimum": 1 },
          "apiRevisionDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "intent": {
      "type": "string",
      "enum": ["default", "help", "author", "review", "repair", "route", "audit", "generate", "batch"]
    },
    "kind": { "type": "string", "enum": ["workflow", "operation"] },
    "targetArtifact": {
      "type": "object",
      "required": ["type", "id"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "contractRevisionDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "projectFactsEvidenceDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "authorization": {
      "type": "object",
      "required": ["sideEffectBudget", "granted"],
      "additionalProperties": false,
      "properties": {
        "sideEffectBudget": {
          "type": "string",
          "enum": ["none", "read-only", "write-authorized-artifacts", "write-review-result", "write-project-artifacts"]
        },
        "granted": {
          "type": "boolean",
          "description": "Recommendation may be emitted with false; execution must separately enforce authorization"
        }
      }
    },
    "registrySnapshot": {
      "type": "object",
      "required": ["digest", "freshness"],
      "additionalProperties": false,
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "freshness": {
          "type": "string",
          "enum": ["fresh", "stale", "missing"]
        }
      }
    },
    "queryDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
