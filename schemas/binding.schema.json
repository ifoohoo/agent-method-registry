{
  "title": "Project Binding",
  "description": "JSON Schema for a v2 project binding in agent-method-registry",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["documentKind", "schemaVersion", "bindings"],
  "properties": {
    "documentKind": {
      "const": "v2-binding",
      "description": "Discriminator for v2 binding documents"
    },
    "schemaVersion": {
      "const": 2
    },
    "bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/binding"
      },
      "minItems": 0
    },
    "serviceBindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/serviceBinding" },
      "minItems": 1
    }
  },
  "$defs": {
    "apiIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiId", "apiMajor", "apiRevisionDigest"],
      "properties": {
        "apiId": {
          "type": "string",
          "pattern": "^(?:artifact\\.[a-z][a-z0-9-]*-family|project\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*-family|(?!(?:artifact|project)\\.)(?:[a-z][a-z0-9-]*\\.){2,}[a-z][a-z0-9-]*-family)$"
        },
        "apiMajor": { "type": "integer", "minimum": 1 },
        "apiRevisionDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "implementationIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["familyImplementationId", "version"],
      "properties": {
        "familyImplementationId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "providerSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "pluginId", "host", "canonicalRoot", "packageDigest", "bundleDigest", "provenance"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["plugin", "project"]
        },
        "pluginId": { "type": "string", "minLength": 1 },
        "projectAuthority": { "type": "string", "pattern": "^project\\.[a-z][a-z0-9-]*$" },
        "host": { "type": "string" },
        "canonicalRoot": { "type": "string", "minLength": 1 },
        "packageDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "bundleDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "provenance": { "type": "string", "minLength": 1 }
      }
    },
    "conformanceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deterministicAttestation": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 digest of deterministic conformance attestation"
        },
        "behaviorQualification": {
          "type": ["string", "null"],
          "description": "Path to behavior qualification evidence"
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familyId",
        "apiIdentity",
        "implementationIdentity",
        "providerSelector",
        "selectionSource",
        "conformanceEvidence"
      ],
      "properties": {
        "familyId": {
          "type": "string",
          "minLength": 1,
          "description": "Family identifier (e.g., e2e-test)"
        },
        "apiIdentity": { "$ref": "#/$defs/apiIdentity" },
        "implementationIdentity": { "$ref": "#/$defs/implementationIdentity" },
        "providerSelector": { "$ref": "#/$defs/providerSelector" },
        "selectionSource": {
          "type": "string",
          "enum": ["project-binding", "unique-compatible", "synthetic-migration"],
          "description": "How this binding was selected"
        },
        "conformanceEvidence": { "$ref": "#/$defs/conformanceEvidence" },
        "authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sideEffectBudget", "granted"],
          "properties": {
            "sideEffectBudget": {
              "type": "string",
              "enum": ["none", "read-only", "write-authorized-artifacts", "write-review-result", "write-project-artifacts"]
            },
            "granted": { "type": "boolean" }
          }
        }
      }
    },
    "serviceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familyId", "serviceId", "apiIdentity", "implementationIdentity",
        "providerSelector", "conformanceEvidence", "interopTckAttestation"
      ],
      "properties": {
        "familyId": { "type": "string", "minLength": 1 },
        "serviceId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2,}$" },
        "apiIdentity": { "$ref": "#/$defs/apiIdentity" },
        "implementationIdentity": { "$ref": "#/$defs/implementationIdentity" },
        "providerSelector": { "$ref": "#/$defs/providerSelector" },
        "conformanceEvidence": { "$ref": "#/$defs/conformanceEvidence" },
        "interopTckAttestation": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sideEffectBudget", "granted"],
          "properties": {
            "sideEffectBudget": {
              "type": "string",
              "enum": ["none", "read-only", "write-authorized-artifacts", "write-review-result", "write-project-artifacts"]
            },
            "granted": { "type": "boolean" }
          }
        }
      }
    }
  },
  "anyOf": [
    { "properties": { "bindings": { "type": "array", "minItems": 1 } } },
    { "required": ["serviceBindings"], "properties": { "serviceBindings": { "type": "array", "minItems": 1 } } }
  ]
}
